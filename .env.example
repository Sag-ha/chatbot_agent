# =============================================================================
# .env.example — Template for your environment variables
#
# INSTRUCTIONS:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in your real values in the new .env file
#   3. NEVER commit .env to Git — it contains secrets!
#      (It is already listed in .gitignore)
#
# WHERE TO FIND THESE VALUES:
#   GCP_PROJECT_ID      → GCP Console → Home → Project ID (top of the page)
#   CLOUD_SQL_INSTANCE  → GCP Console → SQL → Your instance → "Connection name"
#   DB_PASS             → The password you set when creating the Cloud SQL user
#   GCS_BUCKET_NAME     → GCP Console → Cloud Storage → Your bucket name
# =============================================================================

# ── GCP Project ───────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# ── Gemini LLM (Vertex AI) ────────────────────────────────────────────────────
# These defaults are fine — only change if you want a different model
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=text-embedding-004
TEMPERATURE=0.1
MAX_OUTPUT_TOKENS=512

# ── Cloud SQL Database ────────────────────────────────────────────────────────
# Connection name format: "your-project-id:region:instance-name"
# Example:               "my-insurance-app:us-central1:insurance-db"
CLOUD_SQL_INSTANCE=your-project-id:us-central1:your-instance-name

DB_NAME=insurance_db
DB_USER=insurance_user
DB_PASS=your-database-password

VECTOR_TABLE_NAME=insurance_embeddings

# ── Cloud Storage ─────────────────────────────────────────────────────────────
# Name of the GCS bucket where your PDF documents are stored
# Example: "my-insurance-docs-bucket"
GCS_BUCKET_NAME=your-gcs-bucket-name

# Folder path inside the bucket (include trailing slash)
GCS_DOCS_PREFIX=insurance-docs/

# ── RAG Tuning (safe to leave as defaults) ───────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=100
RETRIEVER_K=4
SIMILARITY_THRESHOLD=0.5

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
LOG_LEVEL=info
